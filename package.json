{
  "name": "nrl-fantasy",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "migrate": "node scripts/migrate.js",
    "smoke:production": "node scripts/smoke-production.js",
    "smoke:player-ui": "node scripts/verify-player-ui.js",
    "audit:player-stats": "node scripts/audit-player-stats.js",
    "fetch:nrl-data": "node scripts/fetch-nrl-data.js && node scripts/fetch-team-news.js && node scripts/update-nrl-data.js",
    "fetch:team-news": "node scripts/fetch-team-news.js",
    "audit:round-pipeline": "node scripts/audit-round-pipeline.js",
    "audit:round-pipeline:details": "node scripts/audit-round-pipeline.js --details",
    "smoke:round-ui": "node scripts/verify-round-ui.js",
    "test:browser": "playwright test",
    "check": "node --check server.js && node scripts/check-html.js && node --test",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
